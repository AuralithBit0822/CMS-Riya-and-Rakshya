DJANGO_SECRET_KEY=generate-a-random-secret-key
DJANGO_DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,admin.rnrfood.com
CORS_ALLOWED_ORIGINS=https://rnrfood.com,http://localhost:3000
DATABASE_URL=sqlite:///db.sqlite3

# Email (SMTP) — for forgot password / reset code emails
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=R&R Food Products <your-email@gmail.com>
